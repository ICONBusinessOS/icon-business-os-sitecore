<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/"
               xmlns:set="http://www.sitecore.net/xmlconfig/set/">
  <sitecore>
    <!-- ICON BusinessOS Module Settings -->
    <settings>
      <!-- Tenant identifier - provided during onboarding -->
      <setting name="IconBusinessOS.TenantId" value="" />
      
      <!-- Fleet master URL -->
      <setting name="IconBusinessOS.FleetMasterUrl" value="https://os.theicon.ai/api/silo" />
      
      <!-- Phone home interval in minutes -->
      <setting name="IconBusinessOS.PhoneHomeInterval" value="15" />
      
      <!-- Silo API key (set after registration with fleet master) -->
      <setting name="IconBusinessOS.SiloApiKey" value="" />
      
      <!-- Site display name for fleet dashboard -->
      <setting name="IconBusinessOS.SiteName" value="Sitecore Site" />
    </settings>

    <!-- Register API routes in the initialize pipeline -->
    <pipelines>
      <initialize>
        <processor type="IconBusinessOS.Pipelines.InitializeRoutes, IconBusinessOS"
                   patch:after="processor[@type='Sitecore.Mvc.Pipelines.Loader.InitializeRoutes, Sitecore.Mvc']" />
      </initialize>
    </pipelines>

    <!-- Scheduled Task: Phone Home every 15 minutes -->
    <!-- 
      To activate, create items in Sitecore:
      
      1. /sitecore/system/Tasks/Commands/ICON BusinessOS Phone Home
         - Type: IconBusinessOS.Commands.PhoneHomeCommand, IconBusinessOS
         - Method: Execute
      
      2. /sitecore/system/Tasks/Schedules/ICON BusinessOS Phone Home
         - Command: {reference to command item above}
         - Schedule: 20260101T000000|99991231T235959|900  (every 15 min = 900 seconds)
         - Last Run: (auto-populated)
    -->
  </sitecore>
</configuration>
